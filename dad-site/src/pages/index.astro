  <script>
    const email = document.getElementById("email");
    email.onclick = () => {
      navigator.clipboard.writeText(email.innerText);
    };
  </script>

  <style>
    .wrap {
      display: grid;
      grid-template-columns: 1fr;
      grid-template-rows: 1fr 2rem;
      align-items: flex-start;
      justify-items: center;
      gap: 0.5rem;
      padding: 0.5rem;
      /* border: 2px solid var(--color-accent); */
      border-radius: 0.5rem;
      height: 10rem;
    }

    .brands {
      display: grid;
      grid-template-rows: 4rem 1fr 1fr 1fr 1fr;
      gap: 3rem;
    }

    a {
      text-decoration: none;
      color: black;
    }

    h2 {
      margin: 0.5rem;
      font-size: x-large;
    }
    h3 {
      margin: 0.5rem;
      font-size: large;
    }
    #name {
      font-size: xx-large;
      color: var(--color-accent);
    }
    .accent {
      color: var(--color-accent-alt);
      font-style: italic;
      font-size: x-large;
      font-family: Arial, Helvetica, sans-serif;
    }

    .card {
      text-align: center;
      background-color: white;
      color: black;
      box-shadow: 0.25rem 0.25rem 1rem 0.5rem #111;
      border-radius: 0.25rem;
      object-fit: cover;
      min-width: 17rem;
    }

    .info {
      display: block;
      margin-top: 1rem;
      padding: 1rem 0.5rem;
      font-size: large;
      font-weight: bold;
    }

    .inv {
      filter: invert();
    }

    .photo {
      border-radius: 0.5rem;
      max-width: 14rem;
    }

    .logo {
      object-fit: contain;
      min-width: 15rem;
      max-width: 16rem;
      padding-top: 1rem;
    }

    .wrap svg {
      max-height: 12rem;
    }

    li {
      list-style: none;
      text-align: left;
      padding-inline-start: 1ch;
      font-size: large;
      font-weight: 500;
    }

    #contact {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 0.25rem;
    }

    #pad {
      padding: 1rem;
    }

    #call,
    #email {
      box-shadow: 0.1rem 0.1rem 0.5rem 0.1rem #111;
      border-radius: 0.5rem;
      cursor: pointer;
      padding: 0.5rem;
      margin: 0.5rem;
    }

    /* #call {
    list-style-type: "📞";
  }

  #email {
    list-style-type: "📧";
  } */

    @media (min-width: 768px) {
      .title {
        grid-column: span 2;
      }

      .wrap {
        padding: 1rem 0;
      }
      .wrap svg {
        max-height: 6rem;
      }

      h2 {
        margin: 0.5rem;
        font-size: xx-large;
      }

      h3 {
        margin: 0.5rem;
        font-size: x-large;
      }
      #name {
        font-size: 3rem;
        color: var(--color-accent);
      }

      .info {
        margin-top: 0;
        grid-column: span 2;
        grid-row: span 1;
        display: grid;
        grid-template-columns: 15rem 1fr;
        grid-template-rows: 1fr;
        align-items: center;
        justify-items: center;
        padding: 2rem;
        gap: 2rem;
      }
    }

    @media (min-width: 1380px) {
      .title {
        grid-column: span 2;
        min-height: 4rem;
      }
      h2 {
        margin: 0.5rem;
        font-size: xx-large;
      }

      h3 {
        margin: 0.5rem;
        font-size: large;
      }
      #name {
        font-size: xx-large;
        color: var(--color-accent);
      }
      .info {
        display: block;
        margin: 0 4.5rem 0 0;
        padding: 1rem 0.5rem;
        grid-column: span 1;
        grid-row: span 3;
      }
    }
  </style>
</Page>
